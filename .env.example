# ── Django ───────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Binance (collector) ───────────────────────────────────────────
# Public WebSocket streams — không cần API key
BINANCE_WS_BASE=wss://fstream.binance.com
BINANCE_REST_BASE=https://fapi.binance.com
SYMBOL=BTCUSDT

# ── Notifications (signal/notifier.py) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Model / Trading ───────────────────────────────────────────────
SIGNAL_THRESHOLD=0.60   # Precision ~93% at 0.60, ~96% at 0.70
MIN_RR=1.5
MIN_ROWS_TRAIN=200
