# =============================================================================
# BTC Liquidation Predictor — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
MANIFEST

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.envrc

# -----------------------------------------------------------------------------
# Environment & secrets  (never commit these)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
credentials.json

# -----------------------------------------------------------------------------
# Runtime data  (generated, not source)
# -----------------------------------------------------------------------------
data/raw/
data/processed/
data/*.csv

# -----------------------------------------------------------------------------
# ML artifacts
# -----------------------------------------------------------------------------
ml/artifacts/
catboost_info/
*.pkl
*.joblib
*.h5
wandb/
mlruns/
notebooks/figures/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
nosetests.xml

# -----------------------------------------------------------------------------
# Linting / type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
server/db.sqlite3
*.sqlite3
server/staticfiles/
server/mediafiles/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# System / home directory files  (repo đặt tại ~/)
# -----------------------------------------------------------------------------
.bash_history
.bash_logout
.bashrc
.profile
.wget-hsts
.init_done
.cache/
.config/
.local/
.npm/
.ipython/
.jupyter/
.keras/
.dotnet/
.copilot/
.ssh/
.claude/
.claude.json
.vscode-server/
